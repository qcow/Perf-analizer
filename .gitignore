## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Rider
.idea/
*.sln.iml

# Visual Studio
.vs/
bin/
obj/
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/

# NuGet
*.nupkg
*.snupkg
.nuget/

# Local user-specific files
appsettings.*.json
!appsettings.Development.json
!appsettings.json

# dotnet
project.lock.json
project.fragment.lock.json
artifacts/
.dotnet/

# User-specific files
*.suo
*.sln.iml
